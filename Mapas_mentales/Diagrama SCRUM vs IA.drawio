        <mxCell id="_hCXb_iJXr_RfH__JIMU-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;strokeColor=light-dark(#000000,#99FF99);" value="&lt;span data-start-index=&quot;1553&quot; class=&quot;ng-star-inserted&quot;&gt;Nuevo rol que ayuda en arquitecturas de convivencia con soluciones &lt;/span&gt;&lt;i data-start-index=&quot;1621&quot; class=&quot;ng-star-inserted&quot;&gt;no-code&lt;/i&gt;&lt;span data-start-index=&quot;1628&quot; class=&quot;ng-star-inserted&quot;&gt; e IA&lt;/span&gt;&lt;span class=&quot;ng-star-inserted&quot;&gt;&lt;/span&gt;&lt;span class=&quot;ng-star-inserted&quot;&gt;&lt;/span&gt;&lt;span data-start-index=&quot;1633&quot; class=&quot;ng-star-inserted&quot;&gt;.&lt;/span&gt;" vertex="1">
