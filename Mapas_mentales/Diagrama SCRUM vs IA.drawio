        <mxCell id="_hCXb_iJXr_RfH__JIMU-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;strokeColor=light-dark(#000000,#99FF99);" value="&lt;span data-start-index=&quot;1647&quot; class=&quot;ng-star-inserted&quot;&gt;Se transforma en facilitadór de modelos de trabajo acordes a la convivencia con IA Generativa, ya que las ceremonias tradicionales desaparecen o mutan&lt;/span&gt;" vertex="1">
          <mxGeometry height="83" width="219" x="946" y="-39" as="geometry" />
