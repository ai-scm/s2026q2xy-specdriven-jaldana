        <mxCell id="_hCXb_iJXr_RfH__JIMU-47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontStyle=1;strokeColor=light-dark(#000000,#FF00FF);" value="&lt;span data-start-index=&quot;2752&quot; class=&quot;ng-star-inserted&quot;&gt;Necesidad de técnicas donde una IA supervise lo que genera otra, estableciendo &quot;semáforos&quot; de control&lt;/span&gt;&lt;span class=&quot;ng-star-inserted&quot;&gt;&lt;/span&gt;&lt;span class=&quot;ng-star-inserted&quot;&gt;&lt;/span&gt;&lt;span data-start-index=&quot;2854&quot; class=&quot;ng-star-inserted&quot;&gt;.&lt;/span&gt;" vertex="1">
